{
  "er": "<div className=\"table-responsive border rounded shadow-sm\">\n                                                <Table hover striped bordered className=\"align-middle mb-0 table-sm\">\n                                                    <thead className=\"bg-danger text-white\">\n                                                        <tr>\n                                                            <th>วันที่รับบริการ</th>\n                                                            <th>HN</th>\n                                                            <th>ชื่อ-นามสกุล</th>\n                                                            <th className=\"text-center\">อายุ (ปี)</th>\n                                                            <th>สิทธิ์การรักษา</th>\n                                                            <th>ประเภท ER</th>\n                                                            <th>การวินิจฉัยหลัก</th>\n                                                            <th className=\"text-end\">ค่าใช้จ่าย</th>\n                                                            <th>ที่อยู่</th>\n                                                        </tr>\n                                                    </thead>\n                                                    <tbody>\n                                                        {patientsData.map((pt, idx) => (\n                                                            <tr key={idx}>\n                                                                <td>{new Date(pt.vstdate).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</td>\n                                                                <td><code>{pt.hn}</code></td>\n                                                                <td className=\"fw-semibold\">{pt.ptname}</td>\n                                                                <td className=\"text-center\">{pt.age}</td>\n                                                                <td className=\"small\">{pt.pttypename}</td>\n                                                                <td><span className=\"badge bg-soft-danger text-danger\">{pt.erpttype}</span></td>\n                                                                <td className=\"small\">{pt.dxname || '-'}</td>\n                                                                <td className=\"text-end fw-bold text-danger\">{(pt.income || 0).toLocaleString()}</td>\n                                                                <td className=\"small text-muted\">{pt.address}</td>\n                                                            </tr>\n                                                        ))}\n                                                    </tbody>\n                                                </Table>\n                                            </div>",
  "pcc": "<div className=\"table-responsive border rounded shadow-sm\">\n                                            <Table hover striped bordered className=\"align-middle mb-0 table-sm\">\n                                                <thead className=\"bg-success text-white\">\n                                                    <tr>\n                                                        <th>วันที่รับบริการ</th>\n                                                        <th>HN</th>\n                                                        <th>ชื่อ-นามสกุล</th>\n                                                        <th>อายุ</th>\n                                                        <th>สิทธิ์การรักษา</th>\n                                                        <th>การวินิจฉัยโรคหลัก</th>\n                                                        <th className=\"text-end\">รายได้เรียกเก็บ</th>\n                                                        <th>ที่อยู่</th>\n                                                    </tr>\n                                                </thead>\n                                                <tbody>\n                                                    {patientsData.map((pt, idx) => (\n                                                        <tr key={idx}>\n                                                            <td>{new Date(pt.vstdate).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</td>\n                                                            <td><code>{pt.hn}</code></td>\n                                                            <td className=\"fw-semibold\">{pt.ptname}</td>\n                                                            <td>{pt.age}</td>\n                                                            <td className=\"small\">{pt.pttypename}</td>\n                                                            <td><span className=\"badge bg-soft-success text-success\">{pt.dxname}</span></td>\n                                                            <td className=\"text-end fw-bold text-success\">{(pt.income || 0).toLocaleString()}</td>\n                                                            <td className=\"small text-muted\">{pt.address}</td>\n                                                        </tr>\n                                                    ))}\n                                                </tbody>\n                                            </Table>\n                                        </div>",
  "lab": "<div className=\"table-responsive border rounded shadow-sm\">\n                                            <Table hover striped bordered className=\"align-middle mb-0 table-sm\">\n                                                <thead className=\"bg-info text-white\">\n                                                    <tr>\n                                                        <th>วันที่สั่งแล็บ</th>\n                                                        <th>HN</th>\n                                                        <th>AN</th>\n                                                        <th>ชื่อ-นามสกุล</th>\n                                                        <th>อายุ</th>\n                                                        <th>สิทธิ์การรักษา</th>\n                                                        <th>ชื่อรายการตรวจทางแล็บ</th>\n                                                        <th>ผลการตรวจ (Result)</th>\n                                                        <th>ที่อยู่</th>\n                                                    </tr>\n                                                </thead>\n                                                <tbody>\n                                                    {patientsData.map((pt, idx) => (\n                                                        <tr key={idx}>\n                                                            <td>{new Date(pt.order_date).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</td>\n                                                            <td><code>{pt.hn}</code></td>\n                                                            <td><code>{pt.an || '-'}</code></td>\n                                                            <td className=\"fw-semibold\">{pt.ptname}</td>\n                                                            <td>{pt.age}</td>\n                                                            <td className=\"small\">{pt.pttypename}</td>\n                                                            <td><span className=\"badge bg-soft-info text-info\">{pt.labname}</span></td>\n                                                            <td className=\"fw-bold text-danger\">{pt.result || 'รอดำเนินการ'}</td>\n                                                            <td className=\"small text-muted\">{pt.address}</td>\n                                                        </tr>\n                                                    ))}\n                                                </tbody>\n                                            </Table>\n                                        </div>",
  "xray": "<div className=\"table-responsive border rounded shadow-sm\">\n                                            <Table hover striped bordered className=\"align-middle mb-0 table-sm\">\n                                                <thead className=\"bg-primary text-white\">\n                                                    <tr>\n                                                        <th>วันที่รับบริการ</th>\n                                                        <th>HN</th>\n                                                        <th>AN</th>\n                                                        <th>ชื่อ-นามสกุล</th>\n                                                        <th>อายุ</th>\n                                                        <th>สิทธิ์การรักษา</th>\n                                                        <th>ห้อง/แผนกเอ็กซเรย์</th>\n                                                        <th>ท่าตรวจ/รายการเอ็กซเรย์</th>\n                                                        <th className=\"text-end\">ราคา</th>\n                                                        <th>ที่อยู่</th>\n                                                    </tr>\n                                                </thead>\n                                                <tbody>\n                                                    {patientsData.map((pt, idx) => (\n                                                        <tr key={idx}>\n                                                            <td>{new Date(pt.request_date).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</td>\n                                                            <td><code>{pt.hn}</code></td>\n                                                            <td><code>{pt.an || '-'}</code></td>\n                                                            <td className=\"fw-semibold\">{pt.ptname}</td>\n                                                            <td>{pt.age}</td>\n                                                            <td className=\"small\">{pt.pttypename}</td>\n                                                            <td>{pt.xray_room}</td>\n                                                            <td><span className=\"badge bg-soft-primary text-primary\">{pt.xrayname}</span></td>\n                                                            <td className=\"text-end fw-bold text-primary\">{(pt.price || 0).toLocaleString()}</td>\n                                                            <td className=\"small text-muted\">{pt.address}</td>\n                                                        </tr>\n                                                    ))}\n                                                </tbody>\n                                            </Table>\n                                        </div>",
  "pts": "<div className=\"table-responsive border rounded shadow-sm\">\n                                            <Table hover striped bordered className=\"align-middle mb-0 table-sm\">\n                                                <thead className=\"bg-success text-white\">\n                                                    <tr>\n                                                        <th>วันที่รับบริการ</th>\n                                                        <th>HN</th>\n                                                        <th>AN</th>\n                                                        <th>ชื่อ-นามสกุล</th>\n                                                        <th>อายุ</th>\n                                                        <th>สิทธิ์การรักษา</th>\n                                                        <th>หัตถการ/การรักษาทางกายภาพ</th>\n                                                        <th>การวินิจฉัยโรคหลัก</th>\n                                                        <th className=\"text-end\">ค่าใช้จ่าย</th>\n                                                        <th>ที่อยู่</th>\n                                                    </tr>\n                                                </thead>\n                                                <tbody>\n                                                    {patientsData.map((pt, idx) => (\n                                                        <tr key={idx}>\n                                                            <td>{new Date(pt.service_date).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</td>\n                                                            <td><code>{pt.hn}</code></td>\n                                                            <td><code>{pt.an || '-'}</code></td>\n                                                            <td className=\"fw-semibold\">{pt.ptname}</td>\n                                                            <td>{pt.age}</td>\n                                                            <td className=\"small\">{pt.pttypename}</td>\n                                                            <td><span className=\"badge bg-soft-success text-success\">{pt.itemname}</span></td>\n                                                            <td className=\"small\">{pt.dxname || '-'}</td>\n                                                            <td className=\"text-end fw-bold text-success\">{(pt.income || 0).toLocaleString()}</td>\n                                                            <td className=\"small text-muted\">{pt.address}</td>\n                                                        </tr>\n                                                    ))}\n                                                </tbody>\n                                            </Table>\n                                        </div>",
  "cd": "<div className=\"table-responsive border rounded shadow-sm\">\n                                            <Table hover striped bordered className=\"align-middle mb-0 table-sm\">\n                                                <thead className=\"bg-warning text-white\">\n                                                    <tr>\n                                                        <th>วันที่วินิจฉัย</th>\n                                                        <th>HN</th>\n                                                        <th>ชื่อ-นามสกุล</th>\n                                                        <th>โรคที่เฝ้าระวัง (รง.506)</th>\n                                                        <th>การวินิจฉัยโรค (ICD-10)</th>\n                                                        <th>รายละเอียดโรคหลัก</th>\n                                                        <th>ที่อยู่ผู้ป่วยที่รายงาน</th>\n                                                    </tr>\n                                                </thead>\n                                                <tbody>\n                                                    {patientsData.map((pt, idx) => (\n                                                        <tr key={idx}>\n                                                            <td>{new Date(pt.vstdate).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</td>\n                                                            <td><code>{pt.hn}</code></td>\n                                                            <td className=\"fw-semibold\">{pt.ptname}</td>\n                                                            <td><span className=\"badge bg-soft-danger text-danger\">{pt.name506}</span></td>\n                                                            <td><code>{pt.pdx}</code></td>\n                                                            <td className=\"small\">{pt.dxname}</td>\n                                                            <td className=\"small text-muted\">{pt.address}</td>\n                                                        </tr>\n                                                    ))}\n                                                </tbody>\n                                            </Table>\n                                        </div>",
  "or": "<div className=\"table-responsive border rounded shadow-sm\">\n                                            <Table hover striped bordered className=\"align-middle mb-0 table-sm\">\n                                                <thead className=\"bg-secondary text-white\">\n                                                    <tr>\n                                                        <th>วันที่ผ่าตัด</th>\n                                                        <th>HN</th>\n                                                        <th>AN</th>\n                                                        <th>ชื่อ-นามสกุล</th>\n                                                        <th>อายุ</th>\n                                                        <th>สิทธิ์การรักษา</th>\n                                                        <th>ห้อง/แผนก</th>\n                                                        <th>ประเภทการผ่าตัด</th>\n                                                        <th>ชื่อหัตถการการผ่าตัด</th>\n                                                        <th className=\"text-end\">ค่าใช้จ่าย</th>\n                                                        <th>ที่อยู่</th>\n                                                    </tr>\n                                                </thead>\n                                                <tbody>\n                                                    {patientsData.map((pt, idx) => (\n                                                        <tr key={idx}>\n                                                            <td>{new Date(pt.operation_date).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</td>\n                                                            <td><code>{pt.hn}</code></td>\n                                                            <td><code>{pt.an || '-'}</code></td>\n                                                            <td className=\"fw-semibold\">{pt.ptname}</td>\n                                                            <td>{pt.age}</td>\n                                                            <td className=\"small\">{pt.pttypename}</td>\n                                                            <td>{pt.patient_department}</td>\n                                                            <td><span className=\"badge bg-soft-secondary text-secondary\">{pt.typename}</span></td>\n                                                            <td className=\"small\">{pt.operation_name}</td>\n                                                            <td className=\"text-end fw-bold text-secondary\">{(pt.operation_sum_price || 0).toLocaleString()}</td>\n                                                            <td className=\"small text-muted\">{pt.address}</td>\n                                                        </tr>\n                                                    ))}\n                                                </tbody>\n                                            </Table>\n                                        </div>",
  "ppt": "<div className=\"table-responsive border rounded shadow-sm\">\n                                            <Table hover striped bordered className=\"align-middle mb-0 table-sm\">\n                                                <thead className=\"bg-primary text-white\">\n                                                    <tr>\n                                                        <th>วันที่รับบริการ</th>\n                                                        <th>HN</th>\n                                                        <th>AN</th>\n                                                        <th>ชื่อ-นามสกุล</th>\n                                                        <th className=\"text-center\">อายุ (ปี)</th>\n                                                        <th>สิทธิ์การรักษา</th>\n                                                        <th>ประเภทการบริการ</th>\n                                                        <th>การวินิจฉัยหลัก</th>\n                                                        <th className=\"text-end\">ค่าใช้จ่าย</th>\n                                                        <th>ที่อยู่</th>\n                                                    </tr>\n                                                </thead>\n                                                <tbody>\n                                                    {patientsData.map((pt, idx) => (\n                                                        <tr key={idx}>\n                                                            <td>{new Date(pt.service_date).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</td>\n                                                            <td><code>{pt.hn}</code></td>\n                                                            <td><code>{pt.an || '-'}</code></td>\n                                                            <td className=\"fw-semibold\">{pt.ptname}</td>\n                                                            <td className=\"text-center\">{pt.age}</td>\n                                                            <td className=\"small\">{pt.pttypename}</td>\n                                                            <td><span className=\"badge bg-soft-success text-success\">{pt.ppttname}</span></td>\n                                                            <td className=\"small\">{pt.dxname || '-'}</td>\n                                                            <td className=\"text-end fw-bold text-primary\">{(pt.income || 0).toLocaleString()}</td>\n                                                            <td className=\"small text-muted\">{pt.address}</td>\n                                                        </tr>\n                                                    ))}\n                                                </tbody>\n                                            </Table>\n                                        </div>",
  "dent": "<div className=\"table-responsive border rounded shadow-sm\" style={{ maxHeight: '700px', overflowY: 'auto' }}>\n                                            <Table hover striped bordered className=\"align-middle table-sm mb-0\">\n                                                <thead className=\"sticky-top bg-success text-white\">\n                                                    <tr>\n                                                        <th className=\"text-center\">ลำดับ</th>\n                                                        <th className=\"text-center\">วันที่รับบริการ</th>\n                                                        <th className=\"text-center\">HN</th>\n                                                        <th>ชื่อ-นามสกุล</th>\n                                                        <th className=\"text-center\">อายุ (ปี)</th>\n                                                        <th>ที่อยู่</th>\n                                                        <th>สิทธิการรักษา</th>\n                                                        <th>การวินิจฉัยหลัก (PDx)</th>\n                                                        <th className=\"text-end\">ค่าใช้จ่ายทันตกรรม</th>\n                                                        <th className=\"text-end bg-dark text-white\">ค่าใช้จ่ายรวม</th>\n                                                    </tr>\n                                                </thead>\n                                                <tbody>\n                                                    {patientsData.length === 0 ? (\n                                                        <tr><td colSpan={10} className=\"text-center py-4 text-muted\">ไม่พบข้อมูลรายชื่อสำหรับเดือนนี้</td></tr>\n                                                    ) : patientsData.map((row, idx) => (\n                                                        <tr key={idx}>\n                                                            <td className=\"text-center small text-muted\">{idx + 1}</td>\n                                                            <td className=\"text-center small\">{row.vstdate}</td>\n                                                            <td className=\"text-center small fw-bold text-success\">{row.hn}</td>\n                                                            <td className=\"small fw-semibold\">{row.pname}{row.fname} {row.lname}</td>\n                                                            <td className=\"text-center small\">{row.age_y || '-'}</td>\n                                                            <td className=\"small text-muted\" style={{ maxWidth: '200px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }} title={`${row.addrpart || ''} หมู่ ${row.moopart || ''} ${row.road ? 'ถ.' + row.road : ''} ${row.full_name || ''}`}>\n                                                                {row.addrpart || ''} หมู่ {row.moopart || ''} {row.road ? 'ถ.' + row.road : ''} {row.full_name || ''}\n                                                            </td>\n                                                            <td className=\"small\" style={{ maxWidth: '150px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }} title={row.pttypename}>\n                                                                {row.pttypename}\n                                                            </td>\n                                                            <td className=\"small fw-bold text-primary\">\n                                                                {row.pdx ? `${row.pdx} : ${row.dxname || ''}` : '-'}\n                                                            </td>\n                                                            <td className=\"text-end small text-success fw-bold\">{(row.dent_fee || 0).toLocaleString(undefined, { minimumFractionDigits: 2 })}</td>\n                                                            <td className=\"text-end small bg-light-subtle fw-bold\">{(row.income || 0).toLocaleString(undefined, { minimumFractionDigits: 2 })}</td>\n                                                        </tr>\n                                                    ))}\n                                                </tbody>\n                                            </Table>\n                                        </div>",
  "ncd": "<div className=\"table-responsive border rounded shadow-sm\">\n                                            <Table hover striped bordered className=\"align-middle mb-0 table-sm\">\n                                                <thead className=\"bg-success text-white\">\n                                                    <tr>\n                                                        <th>ลำดับ</th>\n                                                        <th>HN</th>\n                                                        <th>ชื่อ-นามสกุลผู้ลงทะเบียน</th>\n                                                        <th className=\"text-center\">อายุปัจจุบัน (ปี)</th>\n                                                        <th>ทะเบียนโรคหลัก</th>\n                                                        <th>วันที่ลงทะเบียนขึ้นทะเบียน</th>\n                                                        <th>ที่อยู่ตามทะเบียนราษฎร์</th>\n                                                    </tr>\n                                                </thead>\n                                                <tbody>\n                                                    {patientsData.map((pt, idx) => (\n                                                        <tr key={idx}>\n                                                            <td>{idx + 1}</td>\n                                                            <td><code>{pt.hn}</code></td>\n                                                            <td className=\"fw-semibold\">{pt.ptname}</td>\n                                                            <td className=\"text-center\">{pt.age}</td>\n                                                            <td><span className=\"badge bg-soft-success text-success\">{pt.disease}</span></td>\n                                                            <td>{pt.vstdate ? new Date(pt.vstdate).toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' }) : '-'}</td>\n                                                            <td className=\"small text-muted\">{pt.address}</td>\n                                                        </tr>\n                                                    ))}\n                                                </tbody>\n                                            </Table>\n                                        </div>"
}